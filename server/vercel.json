{
  "version": 2,
  "builds": [
    {
      "src": "dist/main.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "dist/main.js"
    }
  ],
  "env": {
    "PROJECT_DOMAIN": "@project-domain",
    "COZE_SUPABASE_URL": "@supabase-url",
    "COZE_SUPABASE_ANON_KEY": "@supabase-anon-key"
  }
}
